@model ComparisonViewModel
@{
    ViewData["Title"] = "Сравнение товаров";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-success"><i class="fas fa-balance-scale me-3"></i>Сравнение товаров</h1>
    @if (Model?.Items?.Any() == true)
    {
        <a asp-action="Clear" class="btn btn-outline-danger" onclick="return confirm('Очистить список сравнения?')">
            <i class="fas fa-trash-alt me-2"></i>Очистить всё
        </a>
    }
</div>

@if (Model?.Items?.Any() == true)
{
    <div class="table-responsive">
        <table class="table table-bordered align-middle comparison-table">
            <thead class="table-success">
                <tr>
                    <th style="width: 200px;">Характеристика</th>
                    @foreach (var product in Model.Items)
                    {
                        <th class="text-center">
                            <img src="@product.PhotoPath" alt="@product.Name" class="img-thumbnail mb-2" style="max-height: 120px;">
                            <br>
                            <a asp-controller="Product" asp-action="Index" asp-route-id="@product.Id" class="text-success fw-bold text-decoration-none">
                                @product.Name
                            </a>
                            <div class="mt-2">
                                <a asp-controller="Cart" asp-action="Add" asp-route-productId="@product.Id" class="btn btn-sm btn-success me-1" title="В корзину">
                                    <i class="fas fa-shopping-cart"></i>
                                </a>
                                <a asp-action="Delete" asp-route-productId="@product.Id" class="btn btn-sm btn-outline-danger" title="Убрать">
                                    <i class="fas fa-times"></i>
                                </a>
                            </div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-semibold">Цена</td>
                    @foreach (var product in Model.Items)
                    {
                        <td class="text-center fw-bold text-danger">@product.Cost.ToString("c")</td>
                    }
                </tr>
                <tr>
                    <td class="fw-semibold">Описание</td>
                    @foreach (var product in Model.Items)
                    {
                        <td class="text-center">@product.Description</td>
                    }
                </tr>
                <!-- Добавьте другие характеристики по необходимости -->
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-balance-scale fa-4x text-muted mb-3"></i>
        <h3 class="text-muted">Список сравнения пуст</h3>
        <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3">
            <i class="fas fa-store me-2"></i>Выбрать товары
        </a>
    </div>
}