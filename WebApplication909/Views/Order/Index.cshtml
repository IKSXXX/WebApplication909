@model OrderViewModel
@{
    ViewData["Title"] = "Оформление заказа";
}

<div class="row">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-header bg-success text-white rounded-top-4 py-3">
                <h4 class="mb-0"><i class="fas fa-truck me-2"></i>Данные получателя</h4>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="DeliveryUser.Name" class="form-label fw-semibold"></label>
                        <input asp-for="DeliveryUser.Name" class="form-control" placeholder="Иванов Иван Иванович">
                        <span asp-validation-for="DeliveryUser.Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DeliveryUser.Address" class="form-label fw-semibold"></label>
                        <input asp-for="DeliveryUser.Address" class="form-control" placeholder="г. Москва, ул. Ленина, д. 1, кв. 1">
                        <span asp-validation-for="DeliveryUser.Address" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DeliveryUser.Phone" class="form-label fw-semibold"></label>
                            <input asp-for="DeliveryUser.Phone" class="form-control" placeholder="+7 (999) 123-45-67">
                            <span asp-validation-for="DeliveryUser.Phone" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DeliveryUser.Date" class="form-label fw-semibold"></label>
                            <input asp-for="DeliveryUser.Date" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                            <span asp-validation-for="DeliveryUser.Date" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DeliveryUser.Comment" class="form-label fw-semibold"></label>
                        <textarea asp-for="DeliveryUser.Comment" class="form-control" rows="3" placeholder="Примечание к заказу (необязательно)"></textarea>
                        <span asp-validation-for="DeliveryUser.Comment" class="text-danger"></span>
                    </div>

                    <button type="submit" asp-action="Buy" class="btn btn-success w-100 py-3 fw-bold">
                        <i class="fas fa-credit-card me-2"></i>Перейти к оплате
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm border-0 rounded-4 sticky-top" style="top: 20px;">
            <div class="card-header bg-success text-white rounded-top-4 py-3">
                <h4 class="mb-0"><i class="fas fa-shopping-basket me-2"></i>Ваш заказ</h4>
            </div>
            <div class="card-body p-4">
                @if (Model?.Items != null && Model.Items.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Items)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span>@item.Product.Name <span class="text-muted">x @item.Quantity</span></span>
                                <span class="fw-bold">@item.Cost.ToString("c")</span>
                            </li>
                        }
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 fw-bold h5 text-success">
                            <span>Итого:</span>
                            <span>@Model.TotalCost?.ToString("c")</span>
                        </li>
                    </ul>
                }
                else
                {
                    <p class="text-muted mb-0">Корзина пуста</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="text-center mt-4">
    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Вернуться в корзину
    </a>
</div>