@model AuthorizationViewModel
@{
    ViewData["Title"] = "Вход в аккаунт";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-success text-white text-center py-4">
                <i class="fas fa-user-circle fa-3x mb-2"></i>
                <h2 class="mb-0">Вход</h2>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Login" class="form-control" placeholder="name@example.com">
                        <label asp-for="Login"><i class="fas fa-envelope me-2"></i>Email</label>
                        <span asp-validation-for="Login" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" class="form-control" placeholder="Password">
                        <label asp-for="Password"><i class="fas fa-lock me-2"></i>Пароль</label>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="IsRememberMe" class="form-check-input">
                        <label asp-for="IsRememberMe" class="form-check-label">Запомнить меня</label>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-3 fw-bold">
                        <i class="fas fa-sign-in-alt me-2"></i>Войти
                    </button>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <span class="text-muted">Нет аккаунта?</span>
                <a asp-controller="Account" asp-action="Registration" class="text-success fw-bold text-decoration-none">Зарегистрироваться</a>
            </div>
        </div>
    </div>
</div>