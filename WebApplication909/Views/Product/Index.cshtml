@model ProductViewModel
@{
    ViewData["Title"] = Model?.Name ?? "Товар";
}

@if (Model != null)
{
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Главная</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <img src="@Model.PhotoPath" class="img-fluid" alt="@Model.Name">
            </div>
        </div>
        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h1 class="display-5 fw-bold text-success">@Model.Name</h1>
                <p class="lead">@Model.Description</p>
                <hr>
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="h2 fw-bold text-danger">@Model.Cost.ToString("c")</span>
                    <div>
                        <a asp-controller="Cart" asp-action="Add" asp-route-productId="@Model.Id" class="btn btn-success btn-lg me-2">
                            <i class="fas fa-shopping-cart me-2"></i>В корзину
                        </a>
                        <a asp-controller="Favorite" asp-action="Add" asp-route-productId="@Model.Id" class="btn btn-outline-danger btn-lg me-2" title="В избранное">
                            <i class="fas fa-heart"></i>
                        </a>
                        <a asp-controller="Comparison" asp-action="Add" asp-route-productId="@Model.Id" class="btn btn-outline-secondary btn-lg" title="Сравнить">
                            <i class="fas fa-balance-scale"></i>
                        </a>
                    </div>
                </div>
                <p class="text-muted"><i class="fas fa-tag me-2"></i>Артикул: @Model.Id</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">Товар не найден</div>
}