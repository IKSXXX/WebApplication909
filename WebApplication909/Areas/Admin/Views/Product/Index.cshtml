@model List<OnlineShop.Db.Models.Product>
@{
    ViewData["Title"] = "Управление товарами";
}

<div class="container">
    <h2 class="text-success">Товары</h2>
    <p>
        <a asp-action="Add" class="btn btn-success">Добавить товар</a>
    </p>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Изображение</th>
                <th>Название</th>
                <th>Цена</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Id</td>
                    <td><img src="@product.PhotoPath" style="max-height: 50px;" /></td>
                    <td>@product.Name</td>
                    <td>@product.Cost.ToString("c")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-primary">Редактировать</a>
                        <form asp-action="Delete" asp-route-id="@product.Id" method="post" style="display:inline;"
                              onsubmit="return confirm('Удалить товар?');">
                            <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>