@model List<WebApplication909.Areas.Admin.Models.RoleViewModel>
@{
    ViewData["Title"] = "Управление ролями";
}

<div class="container mt-4">
    <h2 class="text-success">Роли пользователей</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <p>
        <a asp-action="Create" class="btn btn-success">Создать новую роль</a>
    </p>

    @if (Model.Any())
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Название роли</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in Model)
                {
                    <tr>
                        <td>@role.Id</td>
                        <td>@role.Name</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-sm btn-primary me-1">Редактировать</a>
                            @if (role.Name != "Admin" && role.Name != "User")
                            {
                                <form asp-action="Delete" asp-route-id="@role.Id" method="post" style="display:inline;"
                                      onsubmit="return confirm('Удалить роль @role.Name? Пользователи потеряют эту роль.');">
                                    <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted">Системная роль</span>
                            }
                         </td>
                        </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">Роли не найдены. Создайте первую роль.</div>
    }
</div>