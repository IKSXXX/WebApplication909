@model Order
@{
    ViewData["Title"] = "Детали заказа";
}

<h2>Детали заказа</h2>
<hr />

<div>
    <dl class="row">
        <dt class="col-sm-2">Номер заказа</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Пользователь</dt>
        <dd class="col-sm-10">@Model.UserId</dd>

        <dt class="col-sm-2">Дата создания</dt>
        <dd class="col-sm-10">@Model.CreationDateTime.ToString("g")</dd>

        <dt class="col-sm-2">Статус</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Status)</dd>

        <dt class="col-sm-2">Сумма</dt>
        <dd class="col-sm-10">@Model.TotalCost?.ToString("c")</dd>

        <dt class="col-sm-2">Количество товаров</dt>
        <dd class="col-sm-10">@Model.ItemsQuantity</dd>
    </dl>
</div>

<h4>Состав заказа</h4>
<table class="table">
    <thead>
        <tr>
            <th>Наименование</th>
            <th>Цена</th>
            <th>Количество</th>
            <th>Стоимость</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Items != null)
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Product?.Name</td>
                    <td>@item.Product?.Cost.ToString("c")</td>
                    <td>@item.Quantity</td>
                    <td>@item.Cost.ToString("c")</td>
                </tr>
            }
        }
    </tbody>
</table>

<div>
    <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
</div>